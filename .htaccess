Options -MultiViews
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [QSA,L]

<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed, immutable build assets (JS/CSS/images in /assets) — cache for 1 year
  <FilesMatch "\.(js|css|webp|png|jpg|jpeg|gif|svg|woff2?|ttf|eot)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # HTML must always be revalidated so users get new asset references after a deploy
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|webp|png|jpg|jpeg|gif|svg|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>